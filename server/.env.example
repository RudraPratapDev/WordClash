# Server
PORT=3001

# Comma-separated list for production. Example:
# CORS_ORIGINS=https://wordle-clash.vercel.app,https://www.wordle-clash.com
CORS_ORIGINS=*

# MongoDB (local or Atlas)
# MONGODB_URI=mongodb://127.0.0.1:27017/wordclash
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/wordclash

# Report anti-abuse and hashing controls
WORD_REPORT_WINDOW_MS=600000
WORD_REPORT_MAX_PER_WINDOW=3
WORD_REPORT_REASON_MAX_LENGTH=300
# Set a strong random secret in production
WORD_REPORT_HASH_SALT=replace-with-strong-random-secret

# Mongo connection tuning (optional)
# MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
# MONGODB_MAX_POOL_SIZE=20
# MONGODB_MIN_POOL_SIZE=2

# Optional: timeout for dictionary API checks (milliseconds)
WORD_VALIDATION_TIMEOUT_MS=2500
# Optional: cap total fallback wait for external validation (milliseconds)
WORD_VALIDATION_MAX_WAIT_MS=1800

# CSV-driven word pool controls
# Target words are used for round answers (top N by frequency from CSV files).
WORD_TARGET_THRESHOLD=2000
# WORD_TARGET_THRESHOLD_4=1500
# WORD_TARGET_THRESHOLD_5=1500
# WORD_TARGET_THRESHOLD_6=1500

# Validation thresholds for imported CSV pools.
# Defaults if unset: 4=>9000, 5=>12000, 6=>14000
# Set to 0 to use full CSV for that length.
# WORD_VALIDATION_THRESHOLD=12000
# WORD_VALIDATION_THRESHOLD_4=9000
# WORD_VALIDATION_THRESHOLD_5=12000
# WORD_VALIDATION_THRESHOLD_6=14000

# Validation uses these free sources:
# - https://freedictionaryapi.com/api/v1/entries/en/{word}
# - https://api.dictionaryapi.dev/api/v2/entries/en/{word}
